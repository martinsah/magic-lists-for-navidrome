# Navidrome Configuration
NAVIDROME_URL=http://navidrome:4533

# Use username/password (will login to get token)
NAVIDROME_USERNAME=your_navidrome_username
NAVIDROME_PASSWORD=your_password

# =============================================================================
# AI Configuration
# =============================================================================

# AI Provider Selection
# Options: openrouter, groq, google, ollama
AI_PROVIDER=openrouter

# API Key (required for openrouter, groq, and google; not needed for ollama)
# - Get OpenRouter key: https://openrouter.ai/ ($5 minimum, pay-as-you-go)
# - Get Groq key: https://console.groq.com/ (FREE, no credit card required)
# - Get Google AI key: https://ai.google.dev/ (FREE, generous quota, no credit card required)
AI_API_KEY=your_api_key_here

# Model Selection (optional - defaults provided for each provider)
# OpenRouter: openai/gpt-3.5-turbo, anthropic/claude-3-haiku, openai/gpt-4o-mini, meta-llama/llama-3.3-70b-instruct, etc.
# Groq: mixtral-8x7b-32768, llama-3.1-8b-instant, etc.
# Google: gemini-2.5-flash, gemini-1.5-pro, etc.
# Ollama: llama3.2, mistral, mixtral, etc. (must be pulled first: ollama pull llama3.2)
AI_MODEL=openai/gpt-4o-mini

# Ollama Base URL (only needed if using ollama provider)
# - Running locally without Docker: http://localhost:11434/v1/chat/completions
# - MagicLists in Docker, Ollama on host: http://host.docker.internal:11434/v1/chat/completions
# - Both in same docker-compose: http://ollama:11434/v1/chat/completions
OLLAMA_BASE_URL=http://localhost:11434/v1/chat/completions

# Ollama Request Timeout (only needed if using ollama provider)
# Default: 180 seconds. Increase if you have a slow CPU or large models
# Examples: 300 (5 minutes), 600 (10 minutes), 900 (15 minutes)
OLLAMA_TIMEOUT=180

# Music Path (for Docker Compose)
MUSIC_PATH=/path/to/your/music/library

# Database Configuration
# For Docker: use /app/data/magiclists.db (mounted volume)
# For local development: use ./magiclists.db (current directory)
DATABASE_PATH=/app/data/magiclists.db

# Logging Configuration (ERROR=minimal, INFO=normal, DEBUG=verbose)
LOG_LEVEL=INFO

# Set the ID of the Navidrome library to use (optional)
# Leave empty to use the default library
NAVIDROME_LIBRARY_ID=

# =============================================================================
# Optional: Missing-track recommendations
# =============================================================================

ENABLE_MISSING_RECOMMENDATIONS=false
APPEND_LIBRARY_MATCHES=true
MAX_SUGGESTED_MISSING=10

# =============================================================================
# Optional: Lidarr integration (add missing suggestions to Lidarr)
# =============================================================================

# Set to true to show Add artist / Add album actions in Manage → Playlists
ENABLE_LIDARR_INTEGRATION=false

# Lidarr API base URL (Docker: http://lidarr:8686 — add /lidarr only if behind a subpath proxy)
LIDARR_URL=http://lidarr:8686

# From Lidarr → Settings → General → Security → API Key
LIDARR_API_KEY=

# Root folder path as configured in Lidarr (auto-detected from API if unset)
LIDARR_ROOT_FOLDER=

# Profile IDs (auto-detected from API if unset)
LIDARR_QUALITY_PROFILE_ID=
LIDARR_METADATA_PROFILE_ID=

# Trigger download search when adding (true/false, default true)
LIDARR_SEARCH_ON_ADD=true

# MusicBrainz User-Agent for fallback lookup (required by MB policy when used)
MUSICBRAINZ_USER_AGENT=MagicLists/1.0 (https://github.com/martinsah/magic-lists-for-navidrome)

# =============================================================================
# Optional: Meta-genre distillation defaults (overridable in Genre Insights UI)
# =============================================================================

# coarse | balanced | fine — how many meta-genre groups the AI aims for
META_GENRE_GRANULARITY=balanced